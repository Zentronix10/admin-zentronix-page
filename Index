function updateSendFee(currency) {
    const feeLevel = document.getElementById('sendFee').value;
    const fees = NETWORK_FEES[currency] || NETWORK_FEES.BTC;
    const feeAmount = fees[feeLevel] || fees.medium;
    
    const feeUSD = currency === 'BTC' ? feeAmount * 67200 : 
                   currency === 'ETH' ? feeAmount * 3443 :
                   currency === 'SOL' ? feeAmount * 98.07 :
                   currency === 'LTC' ? feeAmount * 82.50 :
                   currency === 'USDT' ? feeAmount * 1 :
                   currency === 'BRC' ? feeAmount * 9.87 :
                   feeAmount * 0.52;
    
    document.getElementById('sendFeeUSD').textContent = '$' + feeUSD.toFixed(2);
    document.getElementById('sendSummaryFee').textContent = feeAmount.toFixed(8) + ' ' + currency;
    updateSendSummary(currency);
}

function updateSendSummary(currency) {
    const amount = parseFloat(document.getElementById('sendAmount').value) || 0;
    const feeLevel = document.getElementById('sendFee').value;
    const fees = NETWORK_FEES[currency] || NETWORK_FEES.BTC;
    const feeAmount = fees[feeLevel] || fees.medium;
    const total = amount + feeAmount;
    
    document.getElementById('sendSummaryAmount').textContent = amount.toFixed(6) + ' ' + currency;
    document.getElementById('sendSummaryFee').textContent = feeAmount.toFixed(8) + ' ' + currency;
    document.getElementById('sendSummaryTotal').textContent = total.toFixed(6) + ' ' + currency;
}

async function confirmSend() {
    const currency = currentSendCurrency;
    const address = document.getElementById('sendAddress').value.trim();
    const amount = parseFloat(document.getElementById('sendAmount').value);
    const feeLevel = document.getElementById('sendFee').value;
    const fees = NETWORK_FEES[currency] || NETWORK_FEES.BTC;
    const feeAmount = fees[feeLevel] || fees.medium;
    const totalAmount = amount + feeAmount;
    const statusDiv = document.getElementById('sendStatus');
    
    // Validações
    if (!address) {
        statusDiv.innerHTML = '<span style="color:#ff4466;">❌ Please enter a destination address</span>';
        return;
    }
    
    if (!address.startsWith('0x') && !address.startsWith('bc1') && !address.startsWith('ltc1') && !address.startsWith('Sol')) {
        if (!confirm('⚠️ The address format does not match a known blockchain address. Continue anyway?')) {
            return;
        }
    }
    
    if (!amount || amount <= 0) {
        statusDiv.innerHTML = '<span style="color:#ff4466;">❌ Please enter a valid amount</span>';
        return;
    }
    
    if (balances[currency] < totalAmount) {
        statusDiv.innerHTML = `<span style="color:#ff4466;">❌ Insufficient balance! You have ${formatNumber(balances[currency])} ${currency}, need ${formatNumber(totalAmount)} ${currency} (including fee)</span>`;
        return;
    }
    
    // Confirmar transação
    const symbol = CRYPTO_ICONS[currency] || '';
    const confirmMsg = `📤 CONFIRM SEND\n\n` +
                       `Moeda: ${currency}\n` +
                       `Endereço: ${address.substring(0, 15)}...${address.substring(address.length - 10)}\n` +
                       `Quantidade: ${symbol}${formatNumber(amount)} ${currency}\n` +
                       `Taxa: ${symbol}${formatNumber(feeAmount)} ${currency}\n` +
                       `Total: ${symbol}${formatNumber(totalAmount)} ${currency}\n\n` +
                       `⚠️ Esta transação é IRREVERSÍVEL!`;
    
    if (!confirm(confirmMsg)) return;
    
    statusDiv.innerHTML = '<span style="color:#ffaa00;">⏳ Processing transaction on Tatum Mainnet...</span>';
    
    try {
        // ============================================
        //  TATUM API - ENVIAR TRANSAÇÃO REAL
        // ============================================
        const chainMap = {
            'BTC': 'bitcoin',
            'ETH': 'ethereum',
            'SOL': 'solana',
            'LTC': 'litecoin',
            'USDT': 'ethereum',
            'BRC': 'bitcoin',
            'MATIC': 'polygon'
        };
        
        const chain = chainMap[currency] || 'bitcoin';
        const url = `${TATUM_API_URL}/${chain}/transaction`;
        
        // Buscar ou gerar endereço de origem
        const fromAddress = generateAddress(currency);
        
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'x-api-key': TATUM_API_KEY,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                fromAddress: fromAddress,
                toAddress: address,
                amount: amount,
                currency: currency,
                fee: feeAmount
            })
        });
        
        if (!response.ok) {
            throw new Error(`API Error: ${response.status} - ${response.statusText}`);
        }
        
        const data = await response.json();
        
        // Atualizar saldo
        balances[currency] -= totalAmount;
        const txId = data.txId || data.transactionId || 'TX-' + Date.now().toString(36).toUpperCase();
        
        addHistory('SEND', currency, address, amount, totalAmount, txId);
        renderBalances();
        saveBalances();
        
        statusDiv.innerHTML = `<span style="color:#00ff88;">✅ Transaction sent successfully! Tx: ${txId}</span>`;
        showToast(`✅ ${formatNumber(amount)} ${currency} sent to ${address.substring(0, 10)}...`);
        
        // Fechar modal após 3 segundos
        setTimeout(() => {
            closeSendModal();
        }, 3000);
        
    } catch (error) {
        console.error('❌ Send error:', error);
        statusDiv.innerHTML = `<span style="color:#ff4466;">❌ Error: ${error.message}</span>`;
        showToast(`❌ Transaction failed: ${error.message}`);
    }
}

