// ============================================
function generateAddress(currency) {
    const prefixes = {
        BTC: 'bc1q',
        ETH: '0x',
        SOL: 'Sol',
        LTC: 'ltc1q',
        USDT: '0x',
        BRC: 'brc1q',
        MATIC: '0x',
        USD: 'ZNTX',
        EUR: 'ZNTX',
        GBP: 'ZNTX',
        BRL: 'ZNTX'
    };
    const prefix = prefixes[currency] || 'ZNTX';
    return prefix + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 10);
}

