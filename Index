async function generateTatumWallet(currency = 'BTC') {
    const modal = document.getElementById('walletModal');
    document.getElementById('walletTitle').textContent = `⏳ Generating ${currency} Wallet...`;
    document.getElementById('walletAddress').innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Connecting to Tatum Mainnet...';
    document.getElementById('walletPrivateKey').style.display = 'none';
    document.getElementById('walletWarning').textContent = '⏳ Please wait...';
    modal.classList.add('active');
    
    try {
        const chainMap = {
            'BTC': 'bitcoin',
            'ETH': 'ethereum',
            'SOL': 'solana',
            'LTC': 'litecoin',
            'USDT': 'ethereum',
            'BRC': 'bitcoin',
            'MATIC': 'polygon'
        };
        
        const chain = chainMap[currency] || 'bitcoin';
        const url = `${TATUM_API_URL}/${chain}/wallet`;
        
        const response = await fetch(url, {
            method: 'GET',
            headers: {
                'x-api-key': TATUM_API_KEY,
                'Content-Type': 'application/json'
            }
        });
        
        if (!response.ok) {
            throw new Error(`API Error: ${response.status} - ${response.statusText}`);
        }
        
        const data = await response.json();
        
        document.getElementById('walletTitle').textContent = `💰 ${currency} Wallet Generated!`;
        document.getElementById('walletAddress').innerHTML = `
            <strong>📍 Address:</strong><br>${data.address || data.xpub || 'N/A'}<br>
            <button onclick="copyText('${data.address || data.xpub || ''}')" style="margin-top:8px; background:rgba(0,242,255,0.2); border:1px solid #00f2ff; border-radius:5px; padding:4px 12px; cursor:pointer; color:#00f2ff;">📋 Copy</button>
        `;
        
        if (data.privateKey || data.mnemonic) {
            const privateKey = data.privateKey || data.mnemonic;
            document.getElementById('walletPrivateKey').style.display = 'block';
            document.getElementById('walletPrivateKey').innerHTML = `
                <strong>🔑 Private Key (⚠️ NEVER SHARE):</strong><br>${privateKey}<br>
                <button onclick="copyText('${privateKey}')" style="margin-top:8px; background:rgba(255,68,102,0.2); border:1px solid #ff4466; border-radius:5px; padding:4px 12px; cursor:pointer; color:#ff4466;">📋 Copy</button>
            `;
        }
        
        document.getElementById('walletWarning').textContent = '✅ Wallet generated successfully on Tatum Mainnet!';
        document.getElementById('walletWarning').style.color = '#00ff88';
        
        // Salvar wallet
        const wallets = JSON.parse(localStorage.getItem('zentronix_wallets_personal') || '[]');
        wallets.push({
            currency: currency,
            address: data.address || data.xpub || 'N/A',
            privateKey: data.privateKey || data.mnemonic || 'N/A',
            chain: chain,
            timestamp: new Date().toISOString()
        });
        localStorage.setItem('zentronix_wallets_personal', JSON.stringify(wallets));
        
        showToast(`✅ ${currency} wallet generated on Tatum Mainnet!`);
        
    } catch (error) {
        console.error('❌ Tatum Error:', error);
        
        // Fallback: gerar wallet local
        const fallbackAddress = generateAddress(currency);
        document.getElementById('walletTitle').textContent = `⚠️ ${currency} Wallet (Local Fallback)`;
        document.getElementById('walletAddress').innerHTML = `
            <strong>📍 Address (Demo):</strong><br>${fallbackAddress}<br>
            <button onclick="copyText('${fallbackAddress}')" style="margin-top:8px; background:rgba(0,242,255,0.2); border:1px solid #00f2ff; border-radius:5px; padding:4px 12px; cursor:pointer; color:#00f2ff;">📋 Copy</button>
        `;
        document.getElementById('walletWarning').textContent = `⚠️ Tatum API error: ${error.message}. Using local fallback.`;
        document.getElementById('walletWarning').style.color = '#ffaa00';
        
        // Salvar wallet local
        const wallets = JSON.parse(localStorage.getItem('zentronix_wallets_personal') || '[]');
        wallets.push({
            currency: currency,
            address: fallbackAddress,
            privateKey: 'LOCAL_FALLBACK',
            chain: 'local',
            timestamp: new Date().toISOString()
        });
        localStorage.setItem('zentronix_wallets_personal', JSON.stringify(wallets));
        
        showToast(`⚠️ ${currency} wallet generated (local fallback)`);
    }
}

